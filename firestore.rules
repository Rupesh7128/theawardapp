rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    // ----------------------------------------------------------------
    // USERS
    // ----------------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['email', 'createdAt', 'role', 'billingBypass'])
        && request.resource.data.role == 'user'
        && request.resource.data.billingBypass == false
        && !request.resource.data.keys().hasAny(['adminPasscodeHash']);
      allow update: if isAdmin()
        || (isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['email', 'name', 'photoURL', 'lastLoginAt']));
    }

    // ----------------------------------------------------------------
    // AWARDS
    // ----------------------------------------------------------------
    match /awards/{awardId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasAll(['ownerId', 'name', 'status', 'createdAt']);
      allow update: if isAuthenticated()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ----------------------------------------------------------------
    // CATEGORIES
    // ----------------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if true;

      function ownsAward(awardId) {
        return isAuthenticated() &&
          get(/databases/$(database)/documents/awards/$(awardId)).data.ownerId == request.auth.uid;
      }

      allow create: if isAuthenticated() && ownsAward(request.resource.data.awardId);
      allow update, delete: if isAuthenticated()
        && (ownsAward(resource.data.awardId) || isAdmin());
    }

    // ----------------------------------------------------------------
    // NOMINEES
    // ----------------------------------------------------------------
    match /nominees/{nomineeId} {
      allow read: if true;

      function ownsAwardForNominee(awardId) {
        return isAuthenticated() &&
          get(/databases/$(database)/documents/awards/$(awardId)).data.ownerId == request.auth.uid;
      }

      // Public nominations — require minimum fields, prevent junk writes
      allow create: if request.resource.data.keys().hasAll(['awardId', 'categoryId', 'name', 'status', 'voteCount', 'createdAt'])
        && request.resource.data.status == 'pending'
        && request.resource.data.voteCount == 0
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200;

      // Only the award owner can approve/reject nominees.
      // Vote count can only be incremented by 1 at a time, and only on the voteCount field.
      function isValidVoteIncrement() {
        let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
        return changedKeys.hasOnly(['voteCount'])
          && request.resource.data.voteCount == resource.data.voteCount + 1
          && resource.data.status == 'approved';
      }

      allow update: if ownsAwardForNominee(resource.data.awardId)
        || isValidVoteIncrement()
        || isAdmin();
      allow delete: if ownsAwardForNominee(resource.data.awardId) || isAdmin();
    }

    // ----------------------------------------------------------------
    // VOTES
    // Votes are immutable once written.
    // The doc ID must be in format: {sanitizedEmail}_{categoryId}
    // which naturally enforces one vote per email per category.
    // ----------------------------------------------------------------
    match /votes/{voteId} {
      allow read: if isAuthenticated();

      // Validate vote structure — no garbage writes allowed
      allow create: if request.resource.data.keys().hasAll(['awardId', 'categoryId', 'nomineeId', 'voterEmail', 'createdAt'])
        && request.resource.data.voterEmail is string
        && request.resource.data.voterEmail.size() > 0
        && request.resource.data.voterEmail.size() <= 320
        && request.resource.data.voterEmail.matches('.*@.*\\..*')
        && request.resource.data.awardId is string
        && request.resource.data.categoryId is string
        && request.resource.data.nomineeId is string
        // Prevent reading other votes (only your own doc is written)
        && !request.resource.data.keys().hasAny(['adminNotes', 'internal']);

      // Votes can never be modified or deleted (immutable audit trail)
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ----------------------------------------------------------------
    // LEADS
    // Append-only. Only the award owner can read their leads.
    // ----------------------------------------------------------------
    match /leads/{leadId} {
      allow read: if isAuthenticated()
        && get(/databases/$(database)/documents/awards/$(resource.data.awardId)).data.ownerId == request.auth.uid;

      allow create: if request.resource.data.keys().hasAll(['awardId', 'email', 'source', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.matches('.*@.*\\..*')
        && request.resource.data.source in ['vote', 'nomination']
        && request.resource.data.email.size() <= 320;

      allow update: if false;
      allow delete: if false;
    }

    // ----------------------------------------------------------------
    // OTP RECORDS (new — server-side OTP storage)
    // Written by backend only. Client can verify but not read raw code.
    // ----------------------------------------------------------------
    match /otpCodes/{docId} {
      // Only allow create from authenticated backend context
      allow read, write: if false; // managed entirely by Cloud Functions / backend API
    }

    // ----------------------------------------------------------------
    // WAITLIST
    // ----------------------------------------------------------------
    match /waitlist/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.matches('.*@.*\\..*');
      allow update: if false;
      allow read, delete: if isAdmin();
    }
  }
}
